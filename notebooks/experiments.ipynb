    "def select_hyperparams(\n",
    "    model_class, hyperparams: dict, X_train, X_test, y_train, y_test, n_trials\n",
    "):\n",
    "    def objective(trial):\n",
    "        params = {}\n",
    "        for k, v in hyperparams.items():\n",
    "            if isinstance(v[0], int):\n",
    "                if len(v) > 1:\n",
    "                    params[k] = trial.suggest_int(k, v[0], v[1], step=v[2])\n",
    "                else:\n",
    "                    params[k] = trial.suggest_int(k, v[0], v[0])\n",
    "            elif isinstance(v[0], float):\n",
    "                if len(v) > 1:\n",
    "                    params[k] = trial.suggest_float(k, v[0], v[1], step=v[2])\n",
    "                else:\n",
    "                    params[k] = trial.suggest_float(k, v[0], v[0])\n",
    "            else:\n",
    "                params[k] = trial.suggest_categorical(k, v)\n",
    "\n",
    "        model = model_class(**params)\n",
    "        model.fit(X_train, y_train)\n",
    "        predicts = model.predict(X_test)\n",
    "\n",
    "        precision_vals, recall_vals, thresholds = precision_recall_curve(\n",
    "            y_test, predicts\n",
    "        )\n",
    "        pr_auc = auc(recall_vals, precision_vals)\n",
    "        print(f\"PR-AUC: {pr_auc:.2f}\")\n",
    "\n",
    "        return pr_auc\n",
    "\n",
    "    study = optuna.create_study(direction=\"maximize\")\n",
    "    study.optimize(objective, n_trials=n_trials, show_progress_bar=True, n_jobs=-1)\n",
    "\n",
    "    return study"
   ]
  },
