    "def experiments(run_name, model, params: dict, X_train, y_train, X_test, y_test):\n",
    "    with mlflow.start_run(run_name=f\"{run_name}_{model.__class__.__name__}\"):\n",
    "\n",
    "        mlflow.log_params(params)\n",
    "\n",
    "        fitted_model, metrics = model_train(model, X_train, X_test, y_train, y_test)\n",
    "\n",
    "        cm = metrics[\"conf_matrix\"]\n",
    "\n",
    "        mlflow.log_metric(\"tn\", cm[0][0])\n",
    "        mlflow.log_metric(\"fp\", cm[0][1])\n",
    "        mlflow.log_metric(\"fn\", cm[1][0])\n",
    "        mlflow.log_metric(\"tp\", cm[1][1])\n",
    "\n",
    "        log_metrics_mlflow(metrics)\n",
    "\n",
    "        plot_conf_matrix(cm, classes=fitted_model.classes_)\n",
    "        plt.show()\n",
    "        mlflow.log_figure(plt.gcf(), \"cnf_matrix.png\")\n",
    "        plt.close()\n",
    "\n",
    "        plot_pr_auc(\n",
    "            metrics[\"pr_auc\"],\n",
    "            metrics[\"recall_vals\"],\n",
    "            metrics[\"precision_vals\"],\n",
    "        )\n",
    "        plt.show()\n",
    "        mlflow.log_figure(plt.gcf(), \"pr_curve.png\")\n",
    "        plt.close()\n",
    "\n",
    "        mlflow.xgboost.log_model(fitted_model, f\"model_{model.__class__.__name__}\")\n",
    "\n",
    "    return fitted_model"
   ]
  },
